# Settings
MAX_ITERATIONS=3
BERT_SCORE_THRESHOLD=0.92

# Generische LLM Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Logging
LOG_LEVEL=INFO

# Mistral OCR (optional)
MISTRAL_API_KEY=<your_mistral_api_key_here>

# ===== LLM Provider Configuration =====
LLM_PROVIDER=bfh  # 'auto', 'openai', 'bfh'
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# OpenAI
OPENAI_API_KEY=<your_openai_api_key_here>
OPENAI_MODEL=gpt-4o-mini

# BFH-LLM (für Production)
BFH_LLM_ENDPOINT=https://inference.mlmp.ti.bfh.ch/api/v1
BFH_LLM_API_KEY=<your_bfh_llm_api_key_here>
BFH_LLM_MODEL=gpt-oss:120b

# ===== OCR Configuration =====
OCR_DEFAULT_TOOL=auto
OCR_DPI=300
OCR_TESSERACT_LANG=deu+eng

# Domain-spezifische OCR-Präferenzen
OCR_DOMAIN_MATH=mistral
OCR_DOMAIN_LANGUAGES=tesseract
OCR_DOMAIN_ECONOMICS=tesseract

# Pfade
DATA_INPUT_PATH=data/input
DATA_OUTPUT_PATH=data/output
DATA_PARSED_PATH=data/parsed